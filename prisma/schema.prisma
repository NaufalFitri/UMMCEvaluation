generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum ExposureRating {
  UNDER_EXPOSED
  OPTIMAL
  OVER_EXPOSED
}

enum UserRole {
  ADMIN
  ASSESSOR
  STUDENT
}

enum ScheduleStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model User {
  id          String       @id @default(cuid())
  clerkId     String       @unique
  email       String       @unique
  name        String?
  role        UserRole     @default(STUDENT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assessments Evaluation[] @relation("AssessorEvaluations")
  secondaryAssessments Evaluation[] @relation("SecondaryAssessorEvaluations")
  scheduledAsPrimary   AssessmentSchedule[] @relation("PrimaryAssessorSchedules")
  scheduledAsSecondary AssessmentSchedule[] @relation("SecondaryAssessorSchedules")

  @@map("users")
}

model Student {
  id         String       @id @default(cuid())
  studentId  String       @unique
  name       String
  email      String       @unique
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  evaluations Evaluation[]
  schedules  AssessmentSchedule[]

  @@map("students")
}

model Evaluation {
  id               String         @id @default(cuid())
  studentId        String?
  student          Student?       @relation(fields: [studentId], references: [id])
  assessorId       String
  assessor         User           @relation("AssessorEvaluations", fields: [assessorId], references: [id])
  secondaryAssessorId String?
  secondaryAssessor   User?        @relation("SecondaryAssessorEvaluations", fields: [secondaryAssessorId], references: [id])
  
  // Section data (individual storage for each section)
  maklumatPesakitData Json?
  borangPermintaanData Json?
  bilikDanPeralatanData Json?
  jagaanAwalData Json?
  prosedurData Json?
  radiografData Json?
  selepasData Json?
  ulasanAmData Json?
  penilaiKeduaData Json?
  piawanImejData Json?
  discussionData Json?
  finalResultData Json?
  
  // Legacy fields (kept for compatibility)
  preProcedureData Json?
  imageCritiqueData Json?
  procedureRadioData Json?
  postCareData Json?
  historySummaryData Json?
  
  // Tracking
  currentSection   String         @default("pre-procedure-checklist")
  status           String         @default("in-progress")
  completedSections String[]      @default([])
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("evaluations")
}

model AssessmentSchedule {
  id                  String         @id @default(cuid())
  studentId           String
  student             Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  primaryAssessorId   String
  primaryAssessor     User           @relation("PrimaryAssessorSchedules", fields: [primaryAssessorId], references: [id], onDelete: Cascade)
  secondaryAssessorId String?
  secondaryAssessor   User?          @relation("SecondaryAssessorSchedules", fields: [secondaryAssessorId], references: [id], onDelete: SetNull)
  scheduledAt         DateTime
  location            String?
  notes               String?
  status              ScheduleStatus @default(SCHEDULED)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([studentId])
  @@index([primaryAssessorId])
  @@index([secondaryAssessorId])
  @@index([scheduledAt])
  @@map("assessment_schedules")
}
